+
+	/*
+	 * For uncached buffers, flush the CPU cache once now: the __GFP_ZERO
+	 * pages were zeroed by the CPU and are likely cached, so map (which
+	 * implicitly flushes) and immediately unmap on the heap's own device to
+	 * avoid stale cache lines corrupting later uncached access.
+	 */
+	if (uncached) {
+		dma_map_sgtable(dma_heap_get_dev(heap), table, DMA_BIDIRECTIONAL, 0);
+		dma_unmap_sgtable(dma_heap_get_dev(heap), table, DMA_BIDIRECTIONAL, 0);
+	}
+
 	return dmabuf;
 

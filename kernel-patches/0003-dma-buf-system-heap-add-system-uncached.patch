 };
 
+static struct system_heap_priv system_heap_uncached_priv = {
+	.cc_shared = false,
+	.uncached = true,
+};
+
+/* Used until system_heap_create() sets the heap device's DMA mask. */
+static struct dma_buf *system_uncached_heap_not_initialized(struct dma_heap *heap,
+							    unsigned long len,
+							    u32 fd_flags,
+							    u64 heap_flags)
+{
+	return ERR_PTR(-EBUSY);
+}
+
+static struct dma_heap_ops system_uncached_heap_ops = {
+	/* swapped to system_heap_allocate() once the dma mask is set */
+	.allocate = system_uncached_heap_not_initialized,
+};
+
 static int __init system_heap_create(void)
 {
 	struct dma_heap_export_info exp_info;
 	struct dma_heap *sys_heap;
+	struct dma_heap *sys_uncached_heap;
 
 	exp_info.name = "system";
 	exp_info.ops = &system_heap_ops;
@@ -524,6 +573,16 @@
 	if (IS_ERR(sys_heap))
 		return PTR_ERR(sys_heap);
 
+	exp_info.name = "system-uncached";
+	exp_info.ops = &system_uncached_heap_ops;
+	exp_info.priv = &system_heap_uncached_priv;
+	sys_uncached_heap = dma_heap_add(&exp_info);
+	if (IS_ERR(sys_uncached_heap))
+		return PTR_ERR(sys_uncached_heap);
+	dma_coerce_mask_and_coherent(dma_heap_get_dev(sys_uncached_heap), DMA_BIT_MASK(64));
+	mb(); /* publish the dma mask before accepting allocations */
+	system_uncached_heap_ops.allocate = system_heap_allocate;
+
 	if (IS_ENABLED(CONFIG_HIGHMEM) ||
 	    !cc_platform_has(CC_ATTR_MEM_ENCRYPT))
 		return 0;
